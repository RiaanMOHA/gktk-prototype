          "frameIntervalMs": 50,
          "speedFactor": 100,
          "offsetFormula": "dashOffset = ((offsetRef * 100) / 100) % 30",
          "offsetUnit": "%",
          "note": "Only every 3rd polyline is animated (index % 3 === 2), skipping trackBase and trackRails"
        }
      }
