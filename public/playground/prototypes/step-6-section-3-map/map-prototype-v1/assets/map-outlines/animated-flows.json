{
  "_meta": {
    "description": "Complete specification of all animated traffic flows on the MOHA map. Covers four flow systems: Rail Commute, Traffic Flow, Infrastructure Plan corridors, and Property Route. Also includes the static/animated elements that co-render on the Infrastructure Plan layer (impact circles, future zones, company markers).",
    "renderer": "Google Maps JavaScript API polylines with symbol icons",
    "animationEngine": "requestAnimationFrame loop updating icon offsets",
    "replicationNotes": {
      "fullyStatic": [
        "railCommute (all paths hardcoded in this file)",
        "trafficFlow (all paths hardcoded in this file)",
        "infrastructurePlanCorridors (resolved paths cached in infra.json)"
      ],
      "runtimeResolved": [
        "propertyRoute: entirely dynamic based on user-selected property position. No static path to export."
      ],
      "googleMapsApiDependencies": [
        "google.maps.SymbolPath.CIRCLE (numeric constant = 0)",
        "google.maps.Polyline with icons[] array",
        "google.maps.DirectionsService (for corridor and property route resolution)",
        "google.maps.geometry.encoding.decodePath (for Routes API polyline decoding)",
        "google.maps.marker.AdvancedMarkerElement (for company/future markers)",
        "google.maps.Circle (for impact zones)",
        "google.maps.OverlayView (for future zone animated overlays)"
      ]
    }
  },

  "animationSystem": {
    "description": "All animated flows share the same core technique: a Polyline with strokeOpacity: 0 (invisible base stroke) and two icon layers. The first icon is a repeating circle that gets its offset updated each frame to create the illusion of flowing dots. The second icon is a dense 1px-repeat vertical line that fills in a semi-transparent base color.",
    "frameInterval": {
      "description": "Minimum milliseconds between animation updates (checked via timestamp delta)",
      "railCommute": 50,
      "traffic": 50,
      "govPlanCorridors": 40
    },
    "offsetCounter": {
      "description": "A shared counter (offsetRef) increments from 0 to 99 and wraps. Each frame: offsetRef = (offsetRef + 1) % 100. The actual pixel/percent offset is derived from this counter multiplied by a speed factor."
    }
  },

